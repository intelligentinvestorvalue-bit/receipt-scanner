# Copy this file to .env.local and fill in your values.
# See comments below for where to find each value.

# Google Cloud Vision API key (restrict to Cloud Vision API)
# https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=

# Service account email from your downloaded JSON key file
# https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private_key from the same JSON file
# Keep \n as literal backslash-n — do NOT expand to real newlines
GOOGLE_PRIVATE_KEY=

# Spreadsheet ID from the sheet URL: /spreadsheets/d/<ID>/edit
# Share the sheet with the service account email (Editor)
GOOGLE_SHEET_ID=
